{
  "name": "@igovet/opencode-tui-tunnel",
  "author": {
    "name": "Igor Vetrov",
    "email": "igovet@gmail.com",
    "url": "https://vetrov.dev"
  },
  "version": "0.1.8",
  "description": "Web terminal multiplexer for opencode TUI sessions — access your opencode processes from any browser",
  "keywords": [
    "opencode",
    "terminal",
    "tui",
    "tmux",
    "xterm",
    "web-terminal"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/igovet/OpenCode-TUI-Tunnel"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "opencode-tui-tunnel": "./dist/cli/bin.js"
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate-icons": "node scripts/generate-icons.mjs",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsup && node scripts/copy-server-assets.mjs",
    "build:web": "vite build --config web/vite.config.ts",
    "dev:server": "npm run build:web && npm run build:server && concurrently -k -n build,server \"tsup --watch\" \"node --watch dist/cli/bin.js start --no-open\"",
    "dev": "concurrently -k -n server,web \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "vite dev --config web/vite.config.ts",
    "lint": "eslint src web/src",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "fastify": "^5.8.4",
    "node-pty": "^1.1.0",
    "semver": "^7.7.4",
    "sharp": "^0.34.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.5.2",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-plugin-svelte": "^3.17.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "svelte": "^5.55.1",
    "svelte-eslint-parser": "^1.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
