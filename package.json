{
  "name": "opencode-tui-tunnel",
  "version": "0.1.0",
  "description": "Web terminal multiplexer for opencode TUI sessions — access your opencode processes from any browser",
  "keywords": [
    "opencode",
    "terminal",
    "tui",
    "tmux",
    "xterm",
    "web-terminal"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/opencode-tui-tunnel"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "opencode-tui-tunnel": "./dist/cli/bin.js",
    "opencode-tunnel": "./dist/cli/bin.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "generate-icons": "node scripts/generate-icons.mjs",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsup",
    "build:web": "vite build --config web/vite.config.ts",
    "dev:server": "npm run build:server && concurrently -k -n build,server \"tsup --watch\" \"node --watch dist/cli/bin.js start --no-open\"",
    "dev": "concurrently -k -n server,web \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "vite dev --config web/vite.config.ts",
    "lint": "eslint src web/src",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^8.3.1",
    "@types/better-sqlite3": "^7.6.12",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "fastify": "^4.28.1",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^22.15.2",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-svelte": "^2.46.1",
    "prettier": "^3.5.3",
    "svelte": "^5.28.2",
    "svelte-eslint-parser": "^0.43.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.3"
  }
}
